name: KSP Debug

on:
  workflow_dispatch:

jobs:
  ksp-debug:
    runs-on: ubuntu-24.04

    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 21
          cache: gradle

      - uses: gradle/actions/setup-gradle@v4

      - name: Run Room KSP only
        run: |
          chmod +x gradlew
          ./gradlew :app:kspGmsMobileUniversalReleaseKotlin \
            --stacktrace \
            --info \
            --no-daemon

      - name: Upload logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: ksp-debug-log
          path: |
            **/build/reports/**
            **/build/tmp/**
            **/*.log
